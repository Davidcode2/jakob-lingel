---
interface Props {
  title: string;
  mobileScreenshot?: string;
}

const { title, mobileScreenshot } = Astro.props;
---

{
  mobileScreenshot && (
    <div class="hidden absolute bottom-2 lg:flex items-center justify-center p-4 z-0">
      <div class="w-48 xl:w-64 perspective-1000">
        <div
          class="w-[60%] overflow-hidden rounded-lg border-2 border-white/20 shadow-2xl transition-all duration-500 ease-out
               transform-3d perspective-1000
               rotate-x-[28deg] rotate-y-[-20deg] rotate-z-[-2deg] -translate-x-14
               group-hover:rotate-x-0 group-hover:rotate-y-0 group-hover:rotate-z-[-1deg] hover:rotate-z-0 group-hover:scale-125 group-hover:translate-x-12"
        >
          <img
            src={mobileScreenshot}
            alt={`${title} mobile screenshot`}
            class="w-full h-auto object-cover object-top"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  )
}
